# MongoDB Atlas Connection String
# Get your free cluster from https://www.mongodb.com/atlas
# Format: mongodb+srv://<username>:<password>@<cluster-url>/<database-name>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://bankapp:bankapp123@cluster0.mongodb.net/bank-management?retryWrites=true&w=majority

# Server Port
PORT=5003

# Instructions:
# 1. Create a free MongoDB Atlas account at https://www.mongodb.com/atlas
# 2. Create a new cluster (free tier M0)
# 3. Create a database user with username: bankapp, password: bankapp123
# 4. Add your IP address to Network Access (0.0.0.0/0 for all access)
# 5. Get your connection string and replace cluster0.mongodb.net with your actual cluster URL
